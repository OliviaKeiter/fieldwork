---
import AppShell from '../layouts/AppShell.astro';
import IntakeScreen from '../components/IntakeScreen';
import DailyLoopPanel from '../components/DailyLoopPanel';
import JdLibrary from '../components/JdLibrary';
---

<AppShell
  title="Intake"
  active="intake"
  description="Run the daily loop to find and grade new roles, or score a single JD by hand. Graded cards wait below until you file or discard them."
>
  <div class="flex flex-col gap-8">
    <DailyLoopPanel client:load />

    <section>
      <h2 class="mb-3 text-base font-semibold text-text">Score a single JD</h2>
      <IntakeScreen client:load />
    </section>

    <section>
      <h2 class="mb-3 text-base font-semibold text-text">JD library</h2>
      <JdLibrary client:load />
    </section>
  </div>
</AppShell>
